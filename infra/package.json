{
  "name": "pointz-infra",
  "version": "0.1.0",
  "private": true,
  "bin": {
    "pointz-infra": "bin/pointz.js"
  },
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "synth": "npm run build && cdk synth",
    "diff": "npm run build && cdk diff",
    "deploy": "npm run build && cdk deploy --all --require-approval never",
    "destroy": "cdk destroy --all"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.166.0",
    "constructs": "^10.4.2",
    "source-map-support": "^0.5.21"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "aws-cdk": "^2.1020.0",
    "typescript": "^5.7.2"
  }
}
