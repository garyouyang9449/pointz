# Postgres connection string used by the API and drizzle-kit.
DATABASE_URL=postgres://pointz:pointz@localhost:5432/pointz

# Required: secret used to sign JWT auth tokens. Use a long random string.
JWT_SECRET=replace-me-with-a-long-random-string

# Optional: comma-separated list of allowed CORS origins. If unset, all origins are allowed.
# CORS_ORIGINS=http://localhost:5173

# Optional: server bind config.
# PORT=3000
# HOST=0.0.0.0
